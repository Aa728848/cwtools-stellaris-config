nsight drone_conversion_event_effect_2	animator_of_clay_create_vessels	materiality_engine_on_built_effect	pay_proxy_war_additional_resources	try_remove_penal_experimental_mod	add_deposit_with_message	on_psionic_aura_spawned	create_exiled_starhold	electric_storm_apply_aftermath_modifier particle_storm_apply_aftermath_modifier gravity_storm_apply_aftermath_modifier	magnetic_storm_apply_aftermath_modifier	solar_storm_apply_aftermath_modifier celestial_storm_apply_aftermath_modifier shroud_storm_apply_aftermath_modifier	create_enclave_with_country mind_over_matter_immediate reckoning_spawn roll_secret_faction_internal }
