# Built-in on_action completions generated from vanilla Stellaris common/on_actions/*.txt.
# Custom script on_actions are still valid; type[on_action] intentionally has no type_key_filter.

types = {
	## root_completion = subtypes
	type[on_action] = {
		path = "game/common/on_actions"
		# Custom on_actions are legal: only near misses of known keys are hinted.
		error_unknown_keys = suggest
		should_be_used = unless_subtyped
		## starts_with = on_destroy_planet_with_
		## replace_scope = { this = planet root = planet from = fleet }
		subtype[dynamic_planet_killer] = { }
		obsolete_keys = {
			empire_init_capital_planet = "renamed to empire_init_capital_colony"
			on_planet_ascension_tier_increased = "renamed to on_colony_ascension_tier_increased"
			on_planet_attackers_lose = "renamed to on_colony_attackers_lose"
			on_planet_attackers_win = "renamed to on_colony_attackers_win"
