# Validates on_action contents for vanilla and custom on_actions alike:
# referenced events must exist. A random_events weight pointing at 0 means
# "nothing happens".
on_action = {
	## cardinality = 0..1
	events = {
		## cardinality = 0..inf
		<event>
	}
	## cardinality = 0..1
	random_events = {
		## cardinality = 0..inf
		int = <event>
		## cardinality = 0..inf
		int = 0
	}
}
