#I got frustrated at there being SO MANY files, so I have thrown a whole lot together in here -Caligula
#I like to put separate unless I get worn down by too many then I start putting them here - 17blue17 :)

types = {
	type[ambient_object] = {
		name_field = "name"
		path = "game/common/ambient_objects"
		subtype[show_name] = {
			show_name = yes
		}
		localisation = {
			subtype[show_name] = {
				## required
				name = "$"
			}
		}
		subtype[selectable] = {
			selectable = yes
		}
	}
	type[asteroid_belt_type] = { #reason for this rename is the way vanilla names stuff, creating ambiguity.
		path = "game/common/asteroid_belts"
	}
	type[attitude] = {
		path = "game/common/attitudes"
		localisation = {
			## required
			name = "attitude_$"
		}
	}
	type[button_effect] = {
		path = "game/common/button_effects"
	}
	type[country_customization] = {
		path = "game/common/country_customization"
	}
	type[system_type] = {
		path = "game/common/system_types"
		localisation = {
			## required
			name = "$"
		}
	}
	## type_key_filter = part
	type[start_screen_message] = {
		path = "game/common/start_screen_messages"
	}
	type[precursors] = {
		path = "game/common/precursor_civilizations"
	}
	## replace_scope = { root = system this = system }
	type[sector_type] = {
		path = "game/common/sector_types"
		localisation = {
			## required
			name = "$"
		}
	}
	## replace_scope = { root = sector this = sector }
	type[sector_focus] = {
		path = "game/common/sector_focuses"
		subtype[hidden] = {
			hidden = yes
		}
		localisation = {
			subtype[!hidden] = {
				## required
				name = "st_$"
				## required
				desc = "st_$_desc"
			}
		}
	}
	type[map_mode] = {
		path = "game/common/map_modes"
		localisation = {
			## required
			name = "$"
			## required
			desc = "$_desc"
		}
	}
	type[ai_budget] = {
		path = "game/common/ai_budget"
	}
	type[trade_conversion] = {
		path = "game/common/trade_conversions"
	}
	type[economic_plan] = {
		path = "game/common/economic_plans"
	}
	type[artifact_actions] = {
		path = "game/common/artifact_actions"
	}
	type[diplomacy_economy] = {
        path = "game/common/diplomacy_economy"
        type_per_file = yes
	}
	type[message_type] = {
		name_field = key
		path = "game/common/message_types"
		subtype[message] = {
			## cardinality = 0..1
			default_toast = no
		}
		subtype[toast] = {
			default_toast = yes
		}
	}
	type[scripted_modifier] = {
		path = "game/common/scripted_modifiers"
		localisation = {
			## required
			name = "mod_$"
		}
	}
	type[concept] = {
		path = "game/common/game_concepts"
		localisation = {
			## required
			Name = "$"
			## required
			Desc = "$_desc"
		}
	}
	type[concept_categories] = {
		path = "game/common/game_concept_categories"
	}
	type[leader_class] = {
		path = "game/common/leader_classes"
		localisation = {
			## required
			Name = "$"
			## required
			"Name w/Icon" = "$_with_icon"
			## optional
			Plural = "$_plural"
			## optional
			"Plural w/Icon" = "$_plural_with_icon"
			## optional
			Desc = "$_description"
		}
		modifiers = {
			"$_exp_gain" = Leaders
			"$_skill_levels" = Leaders
			"$_skill_add" = Leaders
			"$_initial_skill" = Leaders
			"country_$_cap_add" = Leaders
			"$_lifespan_add" = Leaders
			"$_lifespan_mult" = Leaders
		}
	}
	type[targettype] = {
		path = "game/common/target_types"
	}
	type[tradable_actions] = {
		path = "game/common/tradable_actions" 
	}
	type[leader_tiers] = {
		path = "game/common/leader_tiers"
	}
	
	# Added from rules-sync update report
	type[ai_espionage_operations] = {
		path = "game/common/ai_espionage/operations"
	}
	type[ai_espionage_spynetworks] = {
		path = "game/common/ai_espionage/spynetworks"
	}

	type[cloaking_strength_levels] = {
		path = "game/common/cloaking_strength_levels"
	}
	type[colony_automation_categories] = {
		path = "game/common/colony_automation_categories"
	}
	type[colors] = {
		path = "game/common/colors"
	}
	type[country_container] = {
		path = "game/common/country_container"
	}
	type[dynamic_text] = {
		path = "game/common/dynamic_text"
	}
	type[galactic_community_actions] = {
		path = "game/common/galactic_community_actions"
	}
	type[gamesetup_settings] = {
		path = "game/common/gamesetup_settings"
	}
	type[greeting_overlay_sounds] = {
		path = "game/common/greeting_overlay_sounds"
	}
	type[lawsuits] = {
		path = "game/common/lawsuits"
	}
	type[portrait_categories] = {
		path = "game/common/portrait_categories"
	}
	type[portrait_sets] = {
		path = "game/common/portrait_sets"
	}
	type[random_names_base] = {
		path = "game/common/random_names/base"
	}
	type[resolution_groups] = {
		path = "game/common/resolution_groups"
	}

	type[system_tooltips] = {
		path = "game/common/system_tooltips"
	}
	type[ascension_perk_category] = {
		path = "game/common/ascension_perk_categories"
		localisation = {
			## required
			Name = "$"
			## required
			Desc = "$_desc"
		}
	}
	type[mission_category] = {
		path = "game/common/missions/mission_categories"
		localisation = {
			## required
			Name = "$"
		}
	}
	type[mission] = {
		path = "game/common/missions/missions"
		localisation = {
			## required
			Name = "$"
		}
	}
	type[resource_converter] = {
		path = "game/common/resource_converters"
	}
	type[scripted_action] = {
		path = "game/common/scripted_actions"
	}
	type[situation_log_category] = {
		path = "game/common/situation_log/categories"
		localisation = {
			## required
			Name = "$"
		}
	}
	type[frontend_background] = {
		path = "game/common/frontend_backgrounds"
		localisation = {
			## required
			Name = "$_FRONTEND_NAME"
		}
	}
}

ambient_object = {
	subtype[show_name] = {
		###A localisation key.
		name = localisation
	}
	subtype[!show_name] = {
		name = scalar
	}
	subtype[selectable] = {
		description = localisation
		tooltip = localisation
	}
	subtype[!selectable] = {
		## cardinality = 0..1
		description = localisation
		## cardinality = 0..1
		tooltip = localisation
	}
	entity = <model_entity>
	## cardinality = 0..1
	selectable = bool
	## cardinality = 0..1
	###Determines whether you can read the name of the object ingame.
	show_name = bool
}

asteroid_belt_type = {
	## cardinality = 1..inf
	mesh = scalar
	## cardinality = 0..1
	shader = scalar
	## cardinality = 0..1
	width = float
	## cardinality = 0..1
	density = float
}

attitude = {
	type = scalar
	behaviour = {
		## cardinality = 0..1
		attack = bool
		## cardinality = 0..1
		weaken = bool
		## cardinality = 0..1
		alliance = bool
		## cardinality = 0..1
		vassalize = bool
		## cardinality = 0..1
		trade = bool
		## cardinality = 0..1
		coexist = bool
	}
}

