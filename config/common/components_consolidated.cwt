					dynamic_scale = bool
				}
				## cardinality = 0..inf
				ship_effect = {
					entity = <model_entity>
					dynamic_scale = bool
				}
			}
			## cardinality = 0..1
			damage_per_day = {
				## cardinality = 0..1
				accuracy = float
				## cardinality = 0..1
				damage = { min = float max = float }
				## cardinality = 0..1
				shield_damage = float
				## cardinality = 0..1
				shield_penetration = float
				## cardinality = 0..1
				armor_penetration = float
				## cardinality = 0..1
				size_damage_factor = float
				## cardinality = 0..1
				armor_damage = float
				## cardinality = 0..1
				hull_damage = float
			}
		}
		## cardinality = 0..1
		military_power_multiplier = float
	}
	subtype[weapon_component_template] = {
		size = enum[weapon_slot_size]
		type = enum[weapon_type2]
		projectile_gfx = <projectile> #tied to defined entites under gfx
