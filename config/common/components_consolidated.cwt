			stack_info = {
				id = scalar
				priority = int
			}
			## cardinality = 0..1
			## replace_scope = { this = ship root = ship }
			modifier = {
				## cardinality = 0..1
				custom_tooltip = localisation
				## cardinality = 0..1
				show_only_custom_tooltip = bool
				alias_name[modifier] = alias_match_left[modifier]
			}

			## cardinality = 0..1
			graphics = {
				## cardinality = 0..inf
				area_effect = {
